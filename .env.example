# Copy this file to .env and fill in real values.
# Vars prefixed EXPO_PUBLIC_ are inlined into the client bundle at build time — never put secrets here.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=

# --- Server-side only (Supabase Edge Functions / backend), added in later milestones ---
# Never prefix these with EXPO_PUBLIC_ — they must never ship to the client bundle.
# STRIPE_SECRET_KEY=
# STRIPE_CONNECT_WEBHOOK_SECRET=
# STRIPE_IDENTITY_WEBHOOK_SECRET=
# CHECKR_API_KEY=
